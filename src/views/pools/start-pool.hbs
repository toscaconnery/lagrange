<h1>Start Pool</h1>

<div class="card mt-8" style="">
    <form id="start-pool-form">
        <div class="mb-2">
            <div class="text-lg text-bold">{{pool.label}}</div>
        </div>

        <div class="mb-4">
            <label class="text-sm" for="fish_count">Fish count</label>
            <input type="number" id="fish_count" name="fish_count" placeholder="" style="margin-top: 6px;" value="">
        </div>

        <div class="mb-4">
            <label class="text-sm" for="fish_type">Fish type</label>
            <select id="fish_type" name="fish_type">
                <option value=""></option>
                {{#each fishTypes}}
                    <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
                        {{this.name}}
                    </option>
                {{/each}}
            </select>
        </div>

        <input type="hidden" value="{{pool.id}}" id="pool_id">

        <div id="form-error" class="text-sm" style="color: red; display: none;"></div>
        <div class="flex items-center gap-4 mt-4">
            <button type="submit" class="btn-primary" id="submit-btn">Start</button>

            <a href="/pools/list" class="text-sm text-muted">Cancel</a>
        </div>
    </form>
</div>

<script src="/js/pools/start-pool.js"></script>
