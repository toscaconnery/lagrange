<h1>Add Pool</h1>
<p>Create a new pool.</p>

<div class="card mt-8" style="max-width: 480px;">
    <form id="add-form">
        <div class="mb-4">
            <label class="text-sm" for="label">Label</label>
            <input type="text" id="label" name="label" placeholder="Pool label" required style="margin-top: 6px;">
        </div>

        <div class="mb-4">
            <label class="text-sm" for="fish_species">Fish Species</label>
            <select id="fish_species" name="fish_species">
                <option value="patin" selected>Patin</option>
                <option value="nila">Nila</option>
                <option value="gurame">Gurame</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="text-sm" for="owner">Owner</label>
            <select id="owner" name="owner">
                {{#each users}}
                    <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
            </select>
        </div>

        <div class="mb-4">
            <label class="text-sm" for="fish_count">Fish Count</label>
            <input type="number" disabled id="fish_count" name="fish_count" placeholder="Fish count" style="margin-top: 6px;" value="0">
        </div>

        <div class="mb-4">
            <label class="text-sm" for="status">Status</label>
            <input type="text" disabled id="status" name="status" placeholder="Status" style="margin-top: 6px;" value="inactive">
        </div>

        <div id="form-error" class="text-sm" style="color: red; display: none;"></div>
        <div class="flex items-center gap-4 mt-4">
            <button type="submit" class="btn-primary" id="submit-btn">Add Pool</button>
            <a href="/pools/list" class="text-sm text-muted">Cancel</a>
        </div>
    </form>
</div>

<script src="/js/pools/add-pool.js"></script>