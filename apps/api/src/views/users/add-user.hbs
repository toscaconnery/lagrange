<h1>Add User</h1>
<p>Create a new user account.</p>

<div class="card mt-8" style="max-width: 480px;">
    <form id="add-user-form">
        <div class="mb-4">
            <label class="text-sm" for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required style="margin-top: 6px;">
        </div>
        <div class="mb-4">
            <label class="text-sm" for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="youremail@example.com" required style="margin-top: 6px;">
        </div>
        <div id="form-error" class="text-sm" style="color: red; display: none;"></div>
        <div class="flex items-center gap-4 mt-4">
            <button type="submit" class="btn-primary" id="submit-btn">Add User</button>
            <a href="/users/list" class="text-sm text-muted">Cancel</a>
        </div>
    </form>
</div>

<script src="/js/users/add-user.js"></script>